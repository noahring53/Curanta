# ─────────────────────────────────────────────────────────────────────────────
# Curanta — environment variables
# Copy to .env (local) or set these in Railway → Variables (production).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase — REQUIRED for auth + persistence ───────────────────────────────
# Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key — REQUIRED so Stripe webhooks can update subscriptions.
# Project → Settings → API → service_role (secret). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic — REQUIRED for AI generation ───────────────────────────────────
# Without this the app runs in "mock mode" (placeholder copy, no real AI).
ANTHROPIC_API_KEY=sk-ant-...

# ── App URL — used for Stripe redirect + webhooks ────────────────────────────
# Your deployed URL (no trailing slash). Defaults to the Railway URL if unset.
APP_URL=https://your-app.up.railway.app

# ── Stripe — REQUIRED for subscriptions / trials ─────────────────────────────
# Without these, new users cannot start a trial and AI generation stays gated.
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...
# Price ID for the standard (single-publication) plan — Stripe → Products
STRIPE_PRICE_ID=price_...
# Price ID for the $99/mo multi-publication plan (optional)
STRIPE_MULTI_PRICE_ID=price_...
# Webhook signing secret — Stripe → Developers → Webhooks → your endpoint
# Endpoint URL: https://your-app.up.railway.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Beehiiv — OPTIONAL, for one-click publish ────────────────────────────────
# API key: app.beehiiv.com → Settings → API
BEEHIIV_API_KEY=your-beehiiv-api-key
# Publication ID: shown in the URL when you open your publication in Beehiiv
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
